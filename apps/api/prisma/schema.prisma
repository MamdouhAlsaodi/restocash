generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CASHIER
}

enum PaymentMethod {
  CASH
  PIX
  CARD_DEBIT
  CARD_CREDIT
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(CASHIER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesCreated  Sale[]
  ordersCreated Order[] @relation("OrdersCreated")

  @@index([role])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([isActive, sortOrder])
}

model Product {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  price      Decimal  @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category  Category   @relation(fields: [categoryId], references: [id])
  saleItems SaleItem[]
  orderItems OrderItem[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([isActive])
}

model Sale {
  id              String        @id @default(cuid())
  saleNumber      String        @unique
  totalAmount     Decimal       @db.Decimal(10, 2)
  paymentMethod   PaymentMethod
  status          SaleStatus    @default(COMPLETED)
  createdByUserId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  cancelledAt     DateTime?
  cancelReason    String?

  createdBy User       @relation(fields: [createdByUserId], references: [id])
  items     SaleItem[]

  @@index([createdByUserId])
  @@index([createdAt])
  @@index([status])
  @@index([paymentMethod])
  @@index([status, createdAt])
}

model SaleItem {
  id                  String  @id @default(cuid())
  saleId              String
  productId           String
  productNameSnapshot String
  unitPriceSnapshot   Decimal @db.Decimal(10, 2)
  quantity            Int
  subtotal            Decimal @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

/* ─────────────────────────────────────────────────────────────
 * Order system (Phase: order-ahead, kitchen queue, table mgmt)
 * Schema prepared for upcoming work — not wired into the API yet.
 * Apply with: pnpm prisma migrate dev --name orders-init
 * ─────────────────────────────────────────────────────────── */

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  OPEN
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
}

model RestaurantTable {
  id        String      @id @default(cuid())
  number    Int         @unique
  seats     Int         @default(4)
  status    TableStatus @default(FREE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orders Order[]

  @@index([status])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  type        OrderType
  status      OrderStatus @default(OPEN)
  tableId     String?
  customerName String?
  notes       String?
  totalAmount Decimal     @default(0) @db.Decimal(10, 2)
  createdByUserId String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  closedAt    DateTime?

  table     RestaurantTable? @relation(fields: [tableId], references: [id])
  createdBy User             @relation("OrdersCreated", fields: [createdByUserId], references: [id])
  items     OrderItem[]

  @@index([status])
  @@index([tableId])
  @@index([createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id                  String  @id @default(cuid())
  orderId             String
  productId           String
  productNameSnapshot String
  unitPriceSnapshot   Decimal @db.Decimal(10, 2)
  quantity            Int
  subtotal            Decimal @db.Decimal(10, 2)
  notes               String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}
