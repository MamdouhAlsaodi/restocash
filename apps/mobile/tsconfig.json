{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ESNext"],
    "types": ["react-native"]
  },
  "include": ["src"],
  "extends": "expo/tsconfig.base"
}
